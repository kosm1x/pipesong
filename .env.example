# Telnyx
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=

# Deepgram
DEEPGRAM_API_KEY=

# vLLM (local GPU server)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# Kokoro TTS
KOKORO_VOICE=em_alex
TTS_AGGREGATION_MODE=sentence  # sentence, token, or word (token = lowest latency, may be choppy)

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://pipesong:pipesong@localhost:5432/pipesong

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pipesong-recordings

# App
APP_HOST=0.0.0.0
APP_PORT=8080
APP_PUBLIC_URL=  # e.g. ws://206.168.83.248:8080 — used in Telnyx webhook. If empty, derives from request headers.
DISCLOSURE_TEXT=Esta llamada está siendo grabada para fines de calidad y entrenamiento.
